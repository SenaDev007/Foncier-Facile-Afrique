# Base de données (PostgreSQL, ex. Neon)
# Prisma P1001 (« Can't reach database server ») : projet Neon actif (non suspendu), URL pooler correcte, sslmode=require, pare-feu / réseau.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="+SAQCm3S1lfAR9iR2X+L2r+DnIZQdR2vK8c1gs6bmrk="
# En local : http://localhost:3000 — En prod : l’URL publique exacte (avec ou sans www, mais une seule variante partout ; idéalement https://www.foncierfacileafrique.fr)
NEXTAUTH_URL="https://www.foncierfacileafrique.fr"

# Email (SMTP OVH ou Brevo)
SMTP_HOST="ssl0.ovh.net"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="contact@foncierfacileafrique.fr"
SMTP_PASS="your-email-password"
EMAIL_FROM="Foncier Facile Afrique <contact@foncierfacileafrique.fr>"
EMAIL_ADMIN="isdineidisoule@gmail.com"

# Upload
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="5242880"
# Vercel Blob (production Vercel) : active le stockage persistant pour /api/upload (annonces, etc.). Sinon écriture locale (dev / serveur avec disque).
# Sur Vercel : ajouter le store Blob au projet — la variable est injectée automatiquement ou définir BLOB_READ_WRITE_TOKEN.
# BLOB_READ_WRITE_TOKEN=

# WhatsApp
WHATSAPP_NUMBER="22996901204"

# App (même base que NEXTAUTH_URL en prod : liens absolus SEO, e-mails, FedaPay, réinitialisation mot de passe admin)
NEXT_PUBLIC_SITE_URL="https://www.foncierfacileafrique.fr"
NEXT_PUBLIC_WHATSAPP_NUMBER="22996901204"

# Google Maps (carte contact + vue carte annonces)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="votre_cle_api_google_maps"

# FedaPay (ebooks + réservations séjour)
FEDAPAY_SECRET_KEY="votre_cle_secrete_fedapay"
FEDAPAY_ENV="sandbox"
# Dans le dashboard FedaPay, configurez les webhooks (événement transaction approuvée) vers :
#   https://VOTRE_DOMAINE/api/ebooks/webhook
#   https://VOTRE_DOMAINE/api/reservations/webhook

