generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── UTILISATEURS & AUTH ──────────────────────────────────────────────────────

model User {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  password             String
  role                 Role                 @default(AGENT)
  active               Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  annonces             Annonce[]
  leads                Lead[]               @relation("AssignedLeads")
  blogPosts            BlogPost[]
  dossiersAssignes     DossierFoncier[]     @relation("DossierAssignedUser")
  interactionsDossier  InteractionDossier[]
  passwordResetTokens  PasswordResetToken[]
}

// Jeton à usage unique : réinitialisation mot de passe admin (hash stocké, pas le secret brut).
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
  EDITEUR
}

// ─── ANNONCES IMMOBILIÈRES ────────────────────────────────────────────────────

model Annonce {
  id            String        @id @default(cuid())
  reference     String        @unique
  slug          String        @unique
  titre         String
  description   String
  type          TypeBien
  statut        StatutAnnonce @default(BROUILLON)
  prix          Float
  surface       Float?
  localisation  String
  departement   String?
  commune       String?
  quartier      String?
  latitude      Float?
  longitude     Float?
  documents     String[]
  modalitesPrix String?
  photos        Photo[]
  vues          Int           @default(0)
  auteur        User          @relation(fields: [auteurId], references: [id])
  auteurId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  leads         Lead[]
}

enum TypeBien {
  TERRAIN
  APPARTEMENT
  MAISON
  VILLA
  BUREAU
  COMMERCE
}

enum StatutAnnonce {
  BROUILLON
  EN_LIGNE
  RESERVE
  VENDU
  ARCHIVE
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  ordre     Int      @default(0)
  annonce   Annonce  @relation(fields: [annonceId], references: [id], onDelete: Cascade)
  annonceId String
}

// ─── LEADS / CRM ─────────────────────────────────────────────────────────────

model Lead {
  id             String        @id @default(cuid())
  nom            String
  prenom         String
  telephone      String
  email          String?
  canal          CanalLead     @default(FORMULAIRE)
  budget         String?
  statut         StatutLead    @default(NOUVEAU)
  pole           PoleLead?
  priorite       PrioriteLead?
  notes          String?
  prochainRappel DateTime?
  agent          User?         @relation("AssignedLeads", fields: [agentId], references: [id])
  agentId        String?
  annonce        Annonce?      @relation(fields: [annonceId], references: [id])
  annonceId      String?
  interactions   Interaction[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum PoleLead {
  ACHAT
  VENTE
  CONFIER
  SEJOUR
  REGULARISATION
  AUTRE
}

enum PrioriteLead {
  HAUTE
  NORMALE
  FAIBLE
}

enum CanalLead {
  FORMULAIRE
  WHATSAPP
  APPEL
  EMAIL
  REFERENCE
}

enum StatutLead {
  NOUVEAU
  CONTACTE
  EN_NEGOCIATION
  GAGNE
  PERDU
}

model Interaction {
  id        String   @id @default(cuid())
  type      String
  contenu   String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  createdAt DateTime @default(now())
}

// ─── MESSAGES CONTACT ─────────────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  nom       String
  prenom    String?
  email     String
  telephone String?
  sujet     String?
  contenu   String
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── BLOG ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  titre       String
  resume      String?
  contenu     String
  imageUne    String?
  statut      StatutPost @default(BROUILLON)
  metaTitle   String?
  metaDesc    String?
  tags        String[]
  auteur      User       @relation(fields: [auteurId], references: [id])
  auteurId    String
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum StatutPost {
  BROUILLON
  PLANIFIE
  PUBLIE
  ARCHIVE
}

// ─── TÉMOIGNAGES ──────────────────────────────────────────────────────────────

model Temoignage {
  id        String   @id @default(cuid())
  nom       String
  photo     String?
  texte     String
  note      Int      @default(5)
  actif     Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── PARAMÈTRES SITE ──────────────────────────────────────────────────────────

model Parametre {
  id     String @id @default(cuid())
  cle    String @unique
  valeur String
}

// ─── PAGES & SECTIONS (contenus pilotés par le backoffice) ─────────────────────

model Page {
  id        String        @id @default(cuid())
  slug      String        @unique
  titre     String
  sections  PageSection[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model PageSection {
  id          String   @id @default(cuid())
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId      String
  key         String
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  titre       String?
  sousTitre   String?   @db.Text
  bodyHtml    String?   @db.Text
  imageUrl    String?
  boutonTexte String?
  boutonUrl   String?
  contenuJson String?   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pageId, key])
  @@index([pageId])
}

// ─── NEWSLETTER ───────────────────────────────────────────────────────────────

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── BOUTIQUE EBOOKS & PRODUITS DIGITAUX ───────────────────────────────────────

model Ebook {
  id                String          @id @default(cuid())
  titre             String
  slug              String          @unique
  description       String          @db.Text
  contenu           String?         @db.Text
  prixCFA           Int
  prixPromo         Int?
  codePromo         String?
  codePromoType     String?
  codePromoValeur   Int?
  codePromoExpire   DateTime?
  codePromoUsages   Int             @default(0)
  codePromoMax      Int?
  couverture        String
  fichierPdf        String
  apercuPdf         String?
  pages             Int?
  categorie         String          @default("Guide foncier")
  auteur            String          @default("Foncier Facile Afrique")
  publie            Boolean         @default(false)
  vedette           Boolean         @default(false)
  telechargements   Int             @default(0)
  commandes         CommandeEbook[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model CommandeEbook {
  id             String         @id @default(cuid())
  ebook          Ebook          @relation(fields: [ebookId], references: [id])
  ebookId        String
  acheteurNom    String
  acheteurEmail  String
  acheteurTel    String
  montantPaye    Int
  codePromoUsed  String?
  fedapayTxId    String         @unique
  statut         StatutCommande @default(EN_ATTENTE)
  tokenDownload  String         @unique @default(cuid())
  tokenExpire    DateTime
  downloadCount  Int            @default(0)
  maxDownloads   Int            @default(3)
  createdAt      DateTime       @default(now())
}

enum StatutCommande {
  EN_ATTENTE
  PAYEE
  EXPIREE
  REMBOURSEE
}

// ─── SÉJOUR & TOURISME (spec plateforme v1) ───────────────────────────────────

model Logement {
  id          String         @id @default(cuid())
  reference   String         @unique
  nom         String
  type        TypeLogement
  ville       String
  quartier    String?
  description String          @db.Text
  prixNuit    Float
  capacite    Int
  minNuits    Int             @default(1)
  note        Float?          @default(0)
  nbAvis      Int             @default(0)
  equipements String[]
  services    String[]
  statut      StatutLogement  @default(DISPONIBLE)
  latitude    Float?
  longitude   Float?
  photos      LogementPhoto[]
  reservations Reservation[]
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model LogementPhoto {
  id         String   @id @default(cuid())
  url        String
  alt        String?
  ordre      Int      @default(0)
  logement   Logement @relation(fields: [logementId], references: [id], onDelete: Cascade)
  logementId String
  createdAt  DateTime @default(now())
}

model Reservation {
  id              String        @id @default(cuid())
  reference       String        @unique
  logementId      String
  logement        Logement      @relation(fields: [logementId], references: [id])
  nomVoyageur     String
  email           String
  telephone       String
  pays            String
  nbVoyageurs     Int
  dateArrivee     DateTime
  dateDepart      DateTime
  nbNuits         Int
  montantTotal    Float
  fraisService    Float         @default(10000)
  statut          StatutResa    @default(EN_ATTENTE)
  demandeSpeciale String?       @db.Text
  transfertAero   Boolean       @default(false)
  paymentRef      String?
  paymentStatut   StatutPayment @default(NON_PAYE)
  // Jeton secret page publique /sejour/paiement/[token]
  paymentToken    String?       @unique
  // Id transaction FedaPay (webhook)
  fedapayTxId     String?
  notesAdmin      String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum TypeLogement {
  GUEST_HOUSE
  HOTEL
  VILLA_VAC
  APPARTEMENT
}

enum StatutLogement {
  DISPONIBLE
  OCCUPE
  ARCHIVE
}

enum StatutResa {
  EN_ATTENTE
  CONFIRMEE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum StatutPayment {
  NON_PAYE
  ACOMPTE
  PAYE
}

// ─── RÉGULARISATION FONCIÈRE (spec plateforme v1) ─────────────────────────────

model DossierFoncier {
  id               String               @id @default(cuid())
  reference        String               @unique
  nomClient        String
  emailClient      String
  telephoneClient  String
  pays             String
  typeRegul        TypeRegul
  situationInit    String               @db.Text
  ville            String
  quartier         String?
  etapeActuelle    Int                  @default(1)
  etapeMax         Int                  @default(5)
  statut           StatutDossier        @default(DIAGNOSTIC)
  delaiEstime      String?
  montantDevis     Float?
  notesInternes    String?              @db.Text
  userId           String?
  user             User?                @relation("DossierAssignedUser", fields: [userId], references: [id])
  interactions     InteractionDossier[]
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model InteractionDossier {
  id        String         @id @default(cuid())
  dossierId String
  dossier   DossierFoncier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  type      TypeInteractionDossier
  contenu   String         @db.Text
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())
}

enum TypeRegul {
  PH_TO_TF
  PREMIER_TF
  MUTATION
  LITIGE
  MORCELLEMENT
  AUDIT
}

enum StatutDossier {
  DIAGNOSTIC
  EN_COURS
  ATTENTE_ADMIN
  TERMINE
  SUSPENDU
}

enum TypeInteractionDossier {
  NOTE
  APPEL
  EMAIL
  WHATSAPP
  DOCUMENT
  ETAPE
}
