generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── UTILISATEURS & AUTH ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(AGENT)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  annonces      Annonce[]
  leads         Lead[]    @relation("AssignedLeads")
  blogPosts     BlogPost[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  AGENT
  EDITEUR
}

// ─── ANNONCES IMMOBILIÈRES ────────────────────────────────────────────────────

model Annonce {
  id            String        @id @default(cuid())
  reference     String        @unique
  slug          String        @unique
  titre         String
  description   String
  type          TypeBien
  statut        StatutAnnonce @default(BROUILLON)
  prix          Float
  surface       Float?
  localisation  String
  departement   String?
  commune       String?
  quartier      String?
  latitude      Float?
  longitude     Float?
  documents     String[]
  modalitesPrix String?
  photos        Photo[]
  vues          Int           @default(0)
  auteur        User          @relation(fields: [auteurId], references: [id])
  auteurId      String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  leads         Lead[]
}

enum TypeBien {
  TERRAIN
  APPARTEMENT
  MAISON
  VILLA
  BUREAU
  COMMERCE
}

enum StatutAnnonce {
  BROUILLON
  EN_LIGNE
  RESERVE
  VENDU
  ARCHIVE
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  ordre     Int      @default(0)
  annonce   Annonce  @relation(fields: [annonceId], references: [id], onDelete: Cascade)
  annonceId String
}

// ─── LEADS / CRM ─────────────────────────────────────────────────────────────

model Lead {
  id             String       @id @default(cuid())
  nom            String
  prenom         String
  telephone      String
  email          String?
  canal          CanalLead    @default(FORMULAIRE)
  budget         String?
  statut         StatutLead   @default(NOUVEAU)
  notes          String?
  prochainRappel DateTime?
  agent          User?        @relation("AssignedLeads", fields: [agentId], references: [id])
  agentId        String?
  annonce        Annonce?     @relation(fields: [annonceId], references: [id])
  annonceId      String?
  interactions   Interaction[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum CanalLead {
  FORMULAIRE
  WHATSAPP
  APPEL
  EMAIL
  REFERENCE
}

enum StatutLead {
  NOUVEAU
  CONTACTE
  EN_NEGOCIATION
  GAGNE
  PERDU
}

model Interaction {
  id        String   @id @default(cuid())
  type      String
  contenu   String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  createdAt DateTime @default(now())
}

// ─── MESSAGES CONTACT ─────────────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  nom       String
  prenom    String?
  email     String
  telephone String?
  sujet     String?
  contenu   String
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── BLOG ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  titre       String
  resume      String?
  contenu     String
  imageUne    String?
  statut      StatutPost @default(BROUILLON)
  metaTitle   String?
  metaDesc    String?
  tags        String[]
  auteur      User       @relation(fields: [auteurId], references: [id])
  auteurId    String
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum StatutPost {
  BROUILLON
  PLANIFIE
  PUBLIE
  ARCHIVE
}

// ─── TÉMOIGNAGES ──────────────────────────────────────────────────────────────

model Temoignage {
  id        String   @id @default(cuid())
  nom       String
  photo     String?
  texte     String
  note      Int      @default(5)
  actif     Boolean  @default(true)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── PARAMÈTRES SITE ──────────────────────────────────────────────────────────

model Parametre {
  id     String @id @default(cuid())
  cle    String @unique
  valeur String
}

// ─── PAGES & SECTIONS (contenus pilotés par le backoffice) ─────────────────────

model Page {
  id        String        @id @default(cuid())
  slug      String        @unique
  titre     String
  sections  PageSection[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model PageSection {
  id          String   @id @default(cuid())
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId      String
  key         String
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  titre       String?
  sousTitre   String?   @db.Text
  bodyHtml    String?   @db.Text
  imageUrl    String?
  boutonTexte String?
  boutonUrl   String?
  contenuJson String?   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pageId, key])
  @@index([pageId])
}

// ─── NEWSLETTER ───────────────────────────────────────────────────────────────

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── BOUTIQUE EBOOKS & PRODUITS DIGITAUX ───────────────────────────────────────

model Ebook {
  id                String          @id @default(cuid())
  titre             String
  slug              String          @unique
  description       String          @db.Text
  contenu           String?         @db.Text
  prixCFA           Int
  prixPromo         Int?
  codePromo         String?
  codePromoType     String?
  codePromoValeur   Int?
  codePromoExpire   DateTime?
  codePromoUsages   Int             @default(0)
  codePromoMax      Int?
  couverture        String
  fichierPdf        String
  apercuPdf         String?
  pages             Int?
  categorie         String          @default("Guide foncier")
  auteur            String          @default("Foncier Facile Afrique")
  publie            Boolean         @default(false)
  vedette           Boolean         @default(false)
  telechargements   Int             @default(0)
  commandes         CommandeEbook[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model CommandeEbook {
  id             String         @id @default(cuid())
  ebook          Ebook          @relation(fields: [ebookId], references: [id])
  ebookId        String
  acheteurNom    String
  acheteurEmail  String
  acheteurTel    String
  montantPaye    Int
  codePromoUsed  String?
  fedapayTxId    String         @unique
  statut         StatutCommande @default(EN_ATTENTE)
  tokenDownload  String         @unique @default(cuid())
  tokenExpire    DateTime
  downloadCount  Int            @default(0)
  maxDownloads   Int            @default(3)
  createdAt      DateTime       @default(now())
}

enum StatutCommande {
  EN_ATTENTE
  PAYEE
  EXPIREE
  REMBOURSEE
}
